// Firestore Security Rules for SPERT Forecaster
// Note: The canonical rules file for the full SPERT Suite is in the Firebase Console.
// This file contains only the Forecaster-specific rules for local reference.
// Deploy via Firebase CLI: npx firebase deploy --only firestore:rules --project spert-suite
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // ── SPERT Forecaster ─────────────────────────────────────
    // Note: Forecaster uses a separate `owner` field (not in members map)
    // `members` map contains only editors/viewers
    match /spertforecaster_projects/{projectId} {
      allow list: if isAuth() &&
        (resource.data.owner == request.auth.uid || request.auth.uid in resource.data.members);
      allow get: if isAuth() &&
        (resource.data.owner == request.auth.uid || request.auth.uid in resource.data.members);
      allow create: if isAuth() &&
        request.resource.data.owner == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.owner == request.auth.uid || resource.data.members[request.auth.uid] == 'editor')
                    && (
                      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['owner', 'members']))
                      || resource.data.owner == request.auth.uid
                    );
      allow delete: if isAuth() &&
        resource.data.owner == request.auth.uid;
    }
    match /spertforecaster_profiles/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }
    match /spertforecaster_settings/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    // ToS/Privacy Policy acceptance records
    match /users/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }
  }
}
